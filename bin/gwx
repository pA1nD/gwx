#!/usr/bin/env bash
# gwx — multi-account wrapper around gws (Google Workspace CLI).
# Forces explicit account selection. Allows parallel read fan-out.
# Refuses fan-out for write/unknown verbs (default-deny).

set -euo pipefail

GWX_HOME="${GWX_HOME:-$HOME/.config/gwx}"
GWX_ACCOUNTS_DIR="$GWX_HOME/accounts"
GWX_ACCOUNTS_FILE="$GWX_HOME/accounts.list"
GWX_TIMEOUT="${GWX_TIMEOUT:-30}"
# Validate GWX_TIMEOUT — silently falling back to 30 on garbage input is
# friendlier than aborting, but warn so a typo doesn't get masked.
if ! [[ "$GWX_TIMEOUT" =~ ^[1-9][0-9]*$ ]]; then
  printf 'gwx: GWX_TIMEOUT must be a positive integer (got: %s); using 30\n' "$GWX_TIMEOUT" >&2
  GWX_TIMEOUT=30
fi

RESERVED_WORDS=(init login logout remove whoami skills help all)
READ_VERBS=(list get search schema +triage +agenda +read)
GWX_CACHE_DIR="${GWX_CACHE_DIR:-$HOME/.cache/gwx}"
GWX_SKILLS_SRC="$GWX_CACHE_DIR/skills-src"
GWS_REPO_URL="${GWS_REPO_URL:-https://github.com/googleworkspace/cli}"

err()  { printf 'gwx: %s\n' "$*" >&2; }
die()  { err "$1"; exit "${2:-1}"; }
have() { command -v "$1" >/dev/null 2>&1; }

# print_known_accounts: emit one line listing the alias names this wrapper
# knows about, with a hint that auth status requires `gwx whoami`. Output
# goes to stdout — caller redirects to >&2 for error contexts. We deliberately
# do NOT touch keychain or query auth state here; this is name-discovery only.
# Callers should invoke this on every wrapper-emitted help/error so an agent
# always has the account list one read away, no extra round-trip needed.
print_known_accounts() {
  if [[ -f "$GWX_ACCOUNTS_FILE" ]]; then
    local accts=() line
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -z "${line// }" || "$line" =~ ^[[:space:]]*# ]] && continue
      accts+=("$line")
    done < "$GWX_ACCOUNTS_FILE"
    if [[ "${#accts[@]}" -gt 0 ]]; then
      printf 'known accounts: %s   (run "gwx whoami" for auth status)\n' "${accts[*]}"
      return
    fi
  fi
  printf 'no accounts known yet — run: gwx init <name>\n'
}

# Resolve the absolute path to the gws binary. Priority:
#   1. GWX_GWS_BIN env override (for testing or explicit pinning).
#   2. $GWX_HOME/gws_bin — written by install.sh when gws was detected.
#   3. Whatever 'gws' resolves to in $PATH (last-resort fallback).
# Pinning at install time matters because anything earlier in $PATH at
# call time (e.g. an attacker-controlled ~/.local/bin/gws) would otherwise
# get the OAuth client_id+secret env-exported into it.
GWS_BIN=""
resolve_gws_bin() {
  if [[ -n "${GWX_GWS_BIN:-}" ]]; then
    GWS_BIN="$GWX_GWS_BIN"
  elif [[ -f "$GWX_HOME/gws_bin" ]]; then
    GWS_BIN="$(cat "$GWX_HOME/gws_bin" 2>/dev/null)"
  fi
  if [[ -n "$GWS_BIN" && -x "$GWS_BIN" ]]; then return 0; fi
  GWS_BIN="$(command -v gws 2>/dev/null || true)"
}
ensure_gws() {
  resolve_gws_bin
  [[ -n "$GWS_BIN" ]] || die "gws not installed. install with: npm install -g @googleworkspace/cli" 4
}

is_reserved() {
  local w="$1" r
  [[ "$w" == -* ]] && return 0
  for r in "${RESERVED_WORDS[@]}"; do [[ "$w" == "$r" ]] && return 0; done
  return 1
}

load_accounts() {
  [[ -f "$GWX_ACCOUNTS_FILE" ]] || die "not initialized — run 'gwx init'" 4
  ACCOUNTS=()
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "${line// }" || "$line" =~ ^[[:space:]]*# ]] && continue
    ACCOUNTS+=("$line")
  done < "$GWX_ACCOUNTS_FILE"
  [[ "${#ACCOUNTS[@]}" -gt 0 ]] || die "no accounts configured — run 'gwx init'" 4
}

is_account() {
  local w="$1" a
  for a in "${ACCOUNTS[@]}"; do [[ "$w" == "$a" ]] && return 0; done
  return 1
}

is_read_args() {
  # Match read verbs only in positional args (before the first --flag).
  # Stops scanning as soon as we hit a flag, so a `--subject list` value can't
  # masquerade as the verb and unlock fan-out for an actual write command.
  local a v
  for a in "$@"; do
    [[ "$a" == -* ]] && break
    for v in "${READ_VERBS[@]}"; do [[ "$a" == "$v" ]] && return 0; done
  done
  return 1
}

print_help() {
  cat <<'EOF'
gwx — multi-account wrapper around gws (Google Workspace CLI)

USAGE
  gwx <account>     <gws args...>     run against one account
  gwx <a,b>         <gws args...>     fan-out (read verbs only) — NDJSON output
  gwx all           <gws args...>     fan-out across every account
  gwx <subcommand>  [args]            wrapper-level commands (see SUBCOMMANDS)

DISCOVERING GWS SERVICES & VERBS
  gwx <account> --help                ←  shows the full gws CLI surface (gmail,
                                         drive, calendar, sheets, docs, chat,
                                         admin, +helpers, …). Auto-updates as
                                         gws ships new APIs. Use this when you
                                         don't know which command to run.
  gwx <account> <service> --help      drill into one service
                                      e.g. gwx work gmail --help

SUBCOMMANDS
  init    <name>                      add an account; prompts for OAuth client
                                      (offers to reuse from any existing account)
  login   <account>                   OAuth flow for one account
  logout  <account>                   clear credentials (keep alias)
  remove  <account>                   delete account entirely (alias + creds + client)
  whoami                              email + auth status for every account
  skills install [opts]               install rewritten gws workflow skills
                                      into <cwd>/.claude/skills/ — see
                                      'gwx skills --help' for options
  skills uninstall                    remove rewritten gws skills from cwd

EXAMPLES
  Single-account read:
    gwx work gmail +triage
    gwx personal calendar +agenda --today

  Fan-out read (NDJSON per account):
    gwx all gmail messages list --params '{"q":"q3 review","maxResults":5}'
    gwx work,personal calendar +agenda --today

  Single-account write (fan-out is refused for writes):
    gwx work gmail +send --to a@b.c --subject hi --body hi
    gwx personal drive +upload ./report.pdf

  Pipe the fan-out:
    gwx all gmail messages list --params '{"q":"invoice"}' \
      | jq -s 'map(select(.exit==0) | .stdout.messages[]) | length'

FAN-OUT RULES
  Multi-account fan-out is allowed only when the args contain a known read verb:
    list, get, search, schema, +triage, +agenda, +read
  Anything else (writes, unknown verbs) must target a single account.

EXIT CODES
  0   success
  2   bad usage (missing/unknown account)
  3   fan-out refused (write/unknown verb)
  4   account not authenticated / not initialized
  *   passed through from gws

CONFIG
  ~/.config/gwx/                       wrapper home (mode 0700)
  ~/.config/gwx/accounts.list          one account alias per line
  ~/.config/gwx/keyring_backend  (0600) machine-wide: present iff gws's
                                        AES key store is file-based (auto-set
                                        when OS keychain writes would fail)
  ~/.config/gwx/accounts/<name>/       per-account home (0700)
    ├── client.env       (0600)        OAuth client_id + secret
    ├── credentials.enc  (0600)        refresh token, AES-256-GCM
    ├── token_cache.json (0600)        access token, encrypted
    └── keyring_backend  (0600)        per-account override of the global
                                       backend choice (rarely needed)
  ~/.cache/gwx/skills-src/           shallow clone of gws repo (skills source)
  <cwd>/.claude/skills/<name>/       rewritten skills (per agent project)
  <cwd>/.claude/skills/.gwx-manifest.json   tracks installed skills + SHA
EOF

  # Append known accounts so a single `gwx --help` call gives an agent both
  # the contract AND the live account list — no separate `whoami` needed for
  # orientation. (`whoami` remains the way to check auth status per account.)
  echo
  print_known_accounts
}

print_subcommand_help() {
  case "$1" in
    init) cat <<'EOF'
gwx init — add an account

USAGE
  gwx init <name>                     create a new account (interactive)

The first time you run init, it prompts for an OAuth client_id + client_secret.
Subsequent calls offer to reuse any existing account's client (default), or
provide a new one.

After init, run 'gwx login <name>' to authenticate.
EOF
      ;;
    login) cat <<'EOF'
gwx login — OAuth flow for one account

USAGE
  gwx login <account>                 open browser, sign in, store refresh token

Run once per account. Tokens are AES-256-GCM-encrypted at rest; the key lives
in your OS secret store (macOS Keychain / Windows Credential Manager / Linux
file fallback).

On first login, gwx checks whether the gws binary is ad-hoc-signed on macOS
(Keychain writes will provably fail in that case, errSecInternalError) and
pre-emptively switches to file-based key storage. The choice is persisted
in ~/.config/gwx/keyring_backend so every other account on this machine
also skips the broken first OAuth flow. To force a keychain re-probe,
delete that file before the next login.
EOF
      ;;
    logout) cat <<'EOF'
gwx logout — clear credentials (keep alias)

USAGE
  gwx logout <account>                wipe encrypted tokens; account itself stays
                                      (re-login restores access without re-init)
EOF
      ;;
    remove) cat <<'EOF'
gwx remove — delete an account entirely

USAGE
  gwx remove <account>                remove alias + credentials + OAuth client

Destructive — there is no undo. To just clear tokens (keep the alias for re-login),
use 'gwx logout <account>' instead.
EOF
      ;;
    whoami) cat <<'EOF'
gwx whoami — list accounts and auth status

USAGE
  gwx whoami                          shows ✓ / ✗ / ! per account, with email + scope count

Status legend:
  ✓  authenticated, token valid
  ✗  not logged in (run 'gwx login <name>')
  !  token expired (run 'gwx login <name>' to refresh)
  ?  unable to query (no client.env, or gws auth status failed)
EOF
      ;;
    *) print_help; return 0 ;;
  esac
  echo
  print_known_accounts
}

print_skills_help() {
  cat <<'EOF'
gwx skills — manage rewritten gws workflow skills in the current project

USAGE
  gwx skills install [opts]                 fetch + rewrite + install gws-* skills
                                            into <cwd>/.claude/skills/
  gwx skills uninstall                      remove all installed skills (+ manifest)
  gwx skills uninstall --skill <name>...    remove specific skills only

INSTALL OPTIONS
  --skill <name>...   install only specified skill names (always adds gws-shared)
  --recipes           include recipe-* skills (concrete workflows)
  --personas          include persona-* skills (role-based skills)
  --all               include everything (gws-*, recipe-*, persona-*)

DEFAULT (no flags)   installs every gws-* skill (the per-service workflow files)

EXAMPLES
  cd ~/aip/X002\ -\ Atelier/_agents/officeworker && gwx skills install
  gwx skills install --skill gws-gmail gws-drive    # subset
  gwx skills install --all                          # everything
  gwx skills uninstall

The rewriter adds a ">**NOTE FOR AGENTS:**" banner explaining the gwx wrapper,
then rewrites every gws command (in code blocks, inline backticks, single-quoted
prose, and cliHelp metadata) to use 'gwx <account> ...' syntax.
EOF
  echo
  print_known_accounts
}

prompt_oauth_client() {
  # writes a client.env on stdout — prompts the user for client_id/secret on stderr
  echo "OAuth client for this account." >&2
  echo "Get one from https://console.cloud.google.com → APIs & Services → Credentials" >&2
  echo "→ Create OAuth client ID → Desktop application." >&2
  local cid csec
  read -rp "client_id: " cid
  read -rsp "client_secret: " csec; echo >&2
  [[ -n "$cid" && -n "$csec" ]] || die "client_id and client_secret required" 2
  # Single-quote the values so `source client.env` treats them as literal data.
  # Replaces any embedded ' with '\'' (close-quote, escaped quote, re-open-quote).
  local cid_esc=${cid//\'/\'\\\'\'}
  local csec_esc=${csec//\'/\'\\\'\'}
  cat <<EOF
# OAuth client for this account
GOOGLE_WORKSPACE_CLI_CLIENT_ID='$cid_esc'
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET='$csec_esc'
EOF
}

# discover_clients: prints "label\tpath" per available OAuth client.env
discover_clients() {
  local f
  for f in "$GWX_ACCOUNTS_DIR"/*/client.env; do
    [[ -f "$f" ]] || continue
    printf '%s\t%s\n' "$(basename "$(dirname "$f")")" "$f"
  done
}

# add_one_account: validates alias, prompts for OAuth (with reuse option), writes files.
# Wrapped in a subshell so a setup failure (bad choice, EOF on stdin, etc.) cleans
# up the half-built account dir via EXIT trap. Without this, a failed init leaves
# an orphan dir that whoami doesn't show but `remove` would still need to clean.
add_one_account() (
  local alias="$1"
  validate_alias "$alias"
  if grep -qE "^${alias}\$" "$GWX_ACCOUNTS_FILE" 2>/dev/null; then
    err "alias '$alias' already exists, skipping"
    print_known_accounts >&2
    exit 0
  fi

  local dir="$GWX_ACCOUNTS_DIR/$alias"
  local client_dest="$dir/client.env"
  mkdir -p "$dir"
  chmod 700 "$dir"

  # Cleanup half-built dir on any non-success exit. Cleared at end on success.
  trap 'rm -rf "$dir"' EXIT

  local -a labels=() paths=()
  local line label path
  while IFS=$'\t' read -r label path; do
    [[ -n "$label" ]] || continue
    labels+=("$label"); paths+=("$path")
  done < <(discover_clients)

  if [[ "${#labels[@]}" -gt 0 ]]; then
    echo
    echo "Existing OAuth clients:"
    local i=0
    while [[ "$i" -lt "${#labels[@]}" ]]; do
      printf '  %d) %s\n' "$((i+1))" "${labels[$i]}"
      i=$((i+1))
    done
    echo "  n) provide a new client"
    local choice
    read -rp "Reuse which? [1-${#labels[@]} or n, default 1]: " choice || true
    choice="${choice:-1}"
    if [[ "$choice" == "n" || "$choice" == "new" || "$choice" == "N" ]]; then
      prompt_oauth_client > "$client_dest"
    elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#labels[@]} )); then
      cp "${paths[$((choice-1))]}" "$client_dest"
      echo "✓ copied OAuth client from '${labels[$((choice-1))]}'"
    else
      die "invalid choice: $choice (expected 1-${#labels[@]} or 'n')" 2
    fi
  else
    prompt_oauth_client > "$client_dest"
  fi
  chmod 600 "$client_dest"

  echo "$alias" >> "$GWX_ACCOUNTS_FILE"
  echo "✓ added '$alias' — next: gwx login $alias"

  trap - EXIT  # success — keep the dir
)

cmd_init() {
  case "${1:-}" in -h|--help) print_subcommand_help init; return 0 ;; esac

  mkdir -p "$GWX_HOME" "$GWX_ACCOUNTS_DIR"
  chmod 700 "$GWX_HOME" "$GWX_ACCOUNTS_DIR"
  [[ -f "$GWX_ACCOUNTS_FILE" ]] || { touch "$GWX_ACCOUNTS_FILE"; chmod 600 "$GWX_ACCOUNTS_FILE"; }

  local alias="${1:-}"
  if [[ -z "$alias" ]]; then
    if [[ ! -t 0 ]]; then
      err "usage: gwx init <name>"
      print_known_accounts >&2
      exit 2
    fi
    read -rp "account alias: " alias || true
    if [[ -z "$alias" ]]; then
      err "usage: gwx init <name>"
      print_known_accounts >&2
      exit 2
    fi
  fi
  add_one_account "$alias"
}

scoped_env() {
  local account="$1"
  [[ -d "$GWX_ACCOUNTS_DIR/$account" ]] || die "account dir missing: $GWX_ACCOUNTS_DIR/$account — run 'gwx init $account'" 4
  local client="$GWX_ACCOUNTS_DIR/$account/client.env"
  [[ -f "$client" ]] || die "no OAuth client for '$account' — run 'gwx init $account'" 4
  set -a
  # shellcheck disable=SC1090
  source "$client"
  set +a
  export GOOGLE_WORKSPACE_CLI_CONFIG_DIR="$GWX_ACCOUNTS_DIR/$account"
  # Default: leave GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND unset so gws uses
  # macOS Keychain / Windows Credential Manager — a real OS-level secret
  # store. On Linux, gws's keyring path is compiled out and it uses the
  # file backend regardless.
  #
  # Override hierarchy (per-account first, global second). The keyring
  # backend is a machine-wide property: cmd_login probes once per machine
  # and persists "file" in $GWX_HOME/keyring_backend if the OS keychain
  # is broken (typical: ad-hoc-signed gws on modern macOS), so every
  # account skips that broken first flow. The per-account pref is a niche
  # explicit override — useful if a single account needs a different
  # backend than the rest.
  local backend=""
  local per_account="$GWX_ACCOUNTS_DIR/$account/keyring_backend"
  local global_pref="$GWX_HOME/keyring_backend"
  if [[ -f "$per_account" ]]; then
    backend="$(cat "$per_account" 2>/dev/null || true)"
  elif [[ -f "$global_pref" ]]; then
    backend="$(cat "$global_pref" 2>/dev/null || true)"
  fi
  if [[ "$backend" == "file" ]]; then
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
  fi
}

# gws_keychain_likely_broken: heuristic probe — returns 0 (broken) when
# the installed gws binary is ad-hoc-signed on macOS, which is the
# textbook recipe for `errSecInternalError` on every Keychain write.
# Returns 1 (probably fine) on Linux, Windows, or properly-signed
# binaries — i.e. we still try keychain first in those cases.
#
# Used at first login to skip the doomed first OAuth flow on machines
# where keychain writes will provably fail. Result is cached in
# $GWX_HOME/keyring_backend, so the probe runs at most once per machine.
gws_keychain_likely_broken() {
  [[ "$(uname -s)" == "Darwin" ]] || return 1
  resolve_gws_bin
  [[ -n "$GWS_BIN" ]] || return 1

  # gws_bin may point at a Node entry shim (run.js) that platform-detects
  # and execs the native binary at <pkg>/bin/gws. Probe the native binary,
  # not the shim — the shim is JS and codesign won't tell us anything.
  local probe="$GWS_BIN"
  if [[ "$probe" == *.js ]]; then
    local sib="$(dirname "$probe")/bin/gws"
    [[ -f "$sib" ]] && probe="$sib"
  fi

  have codesign || return 1
  codesign -dv "$probe" 2>&1 | grep -q 'Signature=adhoc' && return 0
  return 1
}

cmd_login() {
  case "${1:-}" in -h|--help) print_subcommand_help login; return 0 ;; esac
  load_accounts
  local account="${1:-}"
  if [[ -z "$account" ]]; then
    err "usage: gwx login <account>"
    print_known_accounts >&2
    exit 2
  fi
  is_account "$account" || die "unknown account '$account'. valid: ${ACCOUNTS[*]}" 2
  ensure_gws
  scoped_env "$account"

  # Pre-probe: on macOS with ad-hoc-signed gws, OS keychain writes are
  # near-certain to fail. Skip a doomed first OAuth flow by switching to
  # file backend up-front and persisting the global pref so every other
  # account on this machine also goes single-flow. scoped_env may have
  # already exported the env var (existing pref); only probe when it
  # didn't.
  local global_pref="$GWX_HOME/keyring_backend"
  if [[ ! -f "$global_pref" ]] \
     && [[ "${GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND:-}" != "file" ]] \
     && gws_keychain_likely_broken; then
    err "Detected ad-hoc-signed gws binary on macOS — OS keychain writes would fail."
    err "Defaulting to file-based key storage to avoid a doomed first OAuth flow."
    err "  ↳ security note: AES key sits at <account>/.encryption_key (mode 0600),"
    err "    still AES-256-GCM at rest, but weaker than keychain."
    echo >&2
    printf 'file\n' > "$global_pref"
    chmod 600 "$global_pref"
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
  fi

  # Run as child (not exec) so we can detect keychain failures and
  # transparently retry with the file backend if needed.
  #
  # Stream both streams LIVE to the user — gws prints the OAuth URL prompt
  # on stderr, so any buffering would make login look hung until after the
  # process exits. We need that stderr both visible (to the user) AND
  # captured (to grep for the keyring-failure pattern). Pattern: a fd swap
  # routes gws's stdout straight to the terminal; gws's stderr enters a
  # foreground pipe to tee, which writes both to the capture file and back
  # out to the terminal. Foreground pipe → tee has fully flushed by the
  # time the pipeline exits, so the post-run grep sees a complete file.
  #
  # set +e window: with `set -euo pipefail` (top of script), a failing gws
  # in a pipeline kills the function immediately — but a keyring failure
  # IS the case we want to handle here. Drop -e for the pipeline only,
  # capture PIPESTATUS, then restore. (`|| true` and `|| _x=$?` both reset
  # PIPESTATUS to 0 on macOS bash, so they aren't viable substitutes.)
  local rc=0 err_file
  err_file=$(mktemp)
  exec 4>&1
  set +e
  { "$GWS_BIN" auth login 2>&1 1>&4 4>&-; } | tee "$err_file" >&2
  rc=${PIPESTATUS[0]}
  set -e
  exec 4>&-

  # Safety-net fallback: the pre-probe missed this case (signed binary
  # that still has keychain trouble, or some non-macOS edge case), but
  # the live error matches the keyring-failure pattern. Retry once with
  # file backend and persist the global pref so every other account on
  # this machine skips the failure entirely. User pays one double-flow.
  if [[ "$rc" -ne 0 && ! -f "$global_pref" ]] \
     && grep -qE 'OS keyring failed|Platform secure storage failure' "$err_file" 2>/dev/null; then
    echo >&2
    err "OS keychain rejected the write — falling back to file-based key storage."
    err "  ↳ security note: the AES key now lives next to the encrypted creds at"
    err "    $GWX_ACCOUNTS_DIR/$account/.encryption_key (mode 0600), not in your"
    err "    OS secret store. Still AES-256-GCM at rest, but weaker than keychain."
    err "  ↳ please complete the OAuth flow one more time."
    echo >&2
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
    rc=0
    "$GWS_BIN" auth login || rc=$?
    if [[ "$rc" -eq 0 ]]; then
      printf 'file\n' > "$global_pref"
      chmod 600 "$global_pref"
    fi
  fi
  rm -f "$err_file"

  if [[ "$rc" -eq 0 ]]; then
    echo
    echo "Next: add another account →  gwx init <name>"
  fi
  return "$rc"
}

validate_alias() {
  local a="$1"
  if is_reserved "$a"; then
    err "alias '$a' collides with reserved keyword (init|login|logout|whoami|skills|account|help|all) or starts with '-'"
    print_known_accounts >&2
    exit 2
  fi
  if [[ ! "$a" =~ ^[a-z0-9_][a-z0-9_-]*$ ]]; then
    err "alias '$a' invalid (use lowercase letters, digits, _, -)"
    print_known_accounts >&2
    exit 2
  fi
}

cmd_remove() {
  case "${1:-}" in -h|--help) print_subcommand_help remove; return 0 ;; esac
  load_accounts
  local a="${1:-}"
  if [[ -z "$a" ]]; then
    err "usage: gwx remove <account>"
    print_known_accounts >&2
    exit 2
  fi
  is_account "$a" || die "unknown account '$a'. valid: ${ACCOUNTS[*]}" 2
  local tmp="$GWX_ACCOUNTS_FILE.tmp.$$"
  grep -v "^${a}\$" "$GWX_ACCOUNTS_FILE" > "$tmp" && mv "$tmp" "$GWX_ACCOUNTS_FILE"
  rm -rf "$GWX_ACCOUNTS_DIR/$a"
  echo "✓ removed '$a' (alias + credentials + OAuth client)"
}


cmd_logout() {
  case "${1:-}" in -h|--help) print_subcommand_help logout; return 0 ;; esac
  load_accounts
  local account="${1:-}"
  if [[ -z "$account" ]]; then
    err "usage: gwx logout <account>"
    print_known_accounts >&2
    exit 2
  fi
  is_account "$account" || die "unknown account '$account'. valid: ${ACCOUNTS[*]}" 2
  local dir="$GWX_ACCOUNTS_DIR/$account"
  rm -f "$dir/credentials.enc" "$dir/token_cache.json" "$dir/sa_token_cache.json" "$dir/.encryption_key" "$dir/client_secret.json" "$dir/keyring_backend"
  echo "✓ removed credentials for '$account' (dir kept: $dir)"
}

cmd_whoami() {
  case "${1:-}" in -h|--help) print_subcommand_help whoami; return 0 ;; esac
  load_accounts
  have gws || die "gws not installed" 4

  # column width based on longest alias (min 8)
  local pad=8 a
  for a in "${ACCOUNTS[@]}"; do (( ${#a} > pad )) && pad=${#a}; done
  pad=$((pad + 2))

  # Status checks fan out in parallel — one `gws auth status` per account
  # is a network call (token validity check), so sequential gets slow fast.
  # Each goes to its own tmp file; we cat them in account order to keep
  # output deterministic.
  local -a tmps pids
  local i=0
  for a in "${ACCOUNTS[@]}"; do
    tmps[$i]=$(mktemp)
    (
      whoami_one_line "$a" "$pad"
    ) >"${tmps[$i]}" 2>/dev/null &
    pids[$i]=$!
    i=$((i+1))
  done

  echo "Accounts:"
  for i in "${!pids[@]}"; do
    wait "${pids[$i]}" 2>/dev/null || true
    cat "${tmps[$i]}"
    rm -f "${tmps[$i]}"
  done
}

# whoami_one_line: emit the single-account status row used by cmd_whoami.
# Pulled into its own function so cmd_whoami can fan it out cleanly.
whoami_one_line() {
  local a="$1" pad="$2"
  if [[ ! -f "$GWX_ACCOUNTS_DIR/$a/client.env" ]]; then
    printf '  %-*s  ?  no OAuth client — run: gwx init %s\n' "$pad" "$a" "$a"
    return
  fi
  scoped_env "$a" 2>/dev/null
  local status method user scopes valid
  if ! status=$(gws auth status 2>/dev/null); then
    printf '  %-*s  ?  unable to query auth status\n' "$pad" "$a"
    return
  fi
  if have jq; then
    method=$(jq -r '.auth_method // "none"' <<<"$status")
    user=$(jq -r '.user // ""' <<<"$status")
    scopes=$(jq -r '.scope_count // 0' <<<"$status")
    valid=$(jq -r '.token_valid // false' <<<"$status")
    if [[ "$method" == "none" || -z "$user" ]]; then
      printf '  %-*s  ✗  not logged in — run: gwx login %s\n' "$pad" "$a" "$a"
    elif [[ "$valid" != "true" ]]; then
      printf '  %-*s  !  %s  (token expired — run: gwx login %s)\n' "$pad" "$a" "$user" "$a"
    else
      printf '  %-*s  ✓  %s  (%s scopes)\n' "$pad" "$a" "$user" "$scopes"
    fi
  else
    if grep -q '"auth_method": *"none"' <<<"$status"; then
      printf '  %-*s  ✗  not logged in — run: gwx login %s\n' "$pad" "$a" "$a"
    else
      printf '  %-*s  ✓  authenticated\n' "$pad" "$a"
    fi
  fi
}

run_one() {
  local account="$1"; shift
  # gws prints "Using keyring backend: keyring" to stderr on every call. It's
  # informational noise, but if a caller does `gwx ... 2>&1 | jq` (or pipes
  # to any JSON parser), that line ends up interleaved with stdout and breaks
  # parsing. Drop it at the wrapper layer — real gws errors still pass through.
  (
    scoped_env "$account"
    if have timeout; then
      timeout "$GWX_TIMEOUT" "$GWS_BIN" "$@"
    else
      "$GWS_BIN" "$@"
    fi
  ) 2> >(grep -v '^Using keyring backend:' >&2)
}

run_one_json() {
  local account="$1"; shift
  local out_file err_file ec start ms stdout_json
  out_file=$(mktemp); err_file=$(mktemp)
  start=$(date +%s)
  set +e
  run_one "$account" "$@" >"$out_file" 2>"$err_file"
  ec=$?
  set -e
  ms=$(( ($(date +%s) - start) * 1000 ))

  if have jq; then
    if stdout_json=$(jq -c '.' "$out_file" 2>/dev/null); then
      jq -nc \
        --arg account "$account" \
        --argjson exit "$ec" \
        --argjson ms "$ms" \
        --argjson stdout "$stdout_json" \
        --rawfile stderr "$err_file" \
        '{account:$account, exit:$exit, duration_ms:$ms, stdout:$stdout, stderr:$stderr}'
    else
      jq -nc \
        --arg account "$account" \
        --argjson exit "$ec" \
        --argjson ms "$ms" \
        --rawfile stdout "$out_file" \
        --rawfile stderr "$err_file" \
        '{account:$account, exit:$exit, duration_ms:$ms, stdout:$stdout, stderr:$stderr}'
    fi
  else
    printf '{"account":"%s","exit":%d,"duration_ms":%d,"raw_stdout_file":"%s"}\n' \
      "$account" "$ec" "$ms" "$out_file"
    return 0
  fi
  rm -f "$out_file" "$err_file"
}

dispatch() {
  load_accounts
  local spec="$1"; shift

  local -a targets
  if [[ "$spec" == "all" ]]; then
    targets=("${ACCOUNTS[@]}")
  elif [[ "$spec" == *,* ]]; then
    IFS=',' read -ra targets <<<"$spec"
  else
    targets=("$spec")
  fi

  for t in "${targets[@]}"; do
    if ! is_account "$t"; then
      err "'$t' is not a known account."
      err "valid accounts: ${ACCOUNTS[*]} (or 'all', or 'a,b' comma-list)"
      err "subcommands: init | login | logout | remove | whoami | skills | --help"
      err "did you forget the account? e.g. 'gwx ${ACCOUNTS[0]} $spec $*'"
      exit 2
    fi
  done

  # --help/-h is single-account by definition. Detect it now so we don't apply
  # fan-out-refusal rules to help requests.
  local has_help=0
  for a in "$@"; do
    if [[ "$a" == "--help" || "$a" == "-h" ]]; then has_help=1; break; fi
  done

  # Wrapper-level fan-out refusal — runs before the gws install check because
  # the rule itself is independent of gws.
  if [[ "${#targets[@]}" -gt 1 && "$has_help" -eq 0 ]] && ! is_read_args "$@"; then
    err "refusing fan-out for non-read command across ${#targets[@]} accounts."
    err "fan-out is allowed only when args contain a read verb: ${READ_VERBS[*]}"
    err "for writes/unknown verbs, target a single account, e.g.:"
    err "  gwx ${targets[0]} $*"
    exit 3
  fi

  ensure_gws

  # Single account, or --help short-circuit (any account's env will do).
  if [[ "$has_help" -eq 1 || "${#targets[@]}" -eq 1 ]]; then
    scoped_env "${targets[0]}"
    exec "$GWS_BIN" "$@"
  fi

  have jq || err "warning: jq not found — output will be degraded"

  local -a pids tmps
  local i=0
  for t in "${targets[@]}"; do
    tmps[$i]=$(mktemp)
    run_one_json "$t" "$@" >"${tmps[$i]}" &
    pids[$i]=$!
    i=$((i+1))
  done
  local fail=0
  for i in "${!pids[@]}"; do
    wait "${pids[$i]}" || fail=1
    cat "${tmps[$i]}"
    rm -f "${tmps[$i]}"
  done
  exit "$fail"
}

# rewrite_skill: adapt an upstream gws skill to gwx's multi-account contract.
#
#   - Adds a "> **NOTE FOR AGENTS:**" banner so any agent reading the skill
#     knows it's wrapped (with link back to upstream gws docs).
#   - Rewrites `gws X` -> `gwx <account> X` in fenced code blocks, inline
#     backticks, single-quoted command refs, and cliHelp: metadata.
#
# Verified across all 95 upstream skills: 0 over-rewrites, 0 broken sibling
# links, 1 deliberate exception (gws-shared's prose description).
rewrite_skill() {
  local script
  IFS= read -r -d '' script <<'PERL' || true
my $banner = "\n> **NOTE FOR AGENTS:** This skill describes the \x60gws\x60 CLI, but you must invoke commands as \x60gwx <account> ...\x60. Direct \x60gws\x60 is blocked by permission rules. See [googleworkspace/cli](https://github.com/googleworkspace/cli) for the underlying tool when debugging.\n";

my ($fm_dashes, $fm_done, $in_code) = (0, 0, 0);
while (<STDIN>) {
  if (!$fm_done && /^---\s*$/) {
    $fm_dashes++; print;
    if ($fm_dashes == 2) { $fm_done = 1; print $banner; }
    next;
  }
  if (/^\s*\x60\x60\x60/) { $in_code = !$in_code; print; next }
  s/\x60gws\s+/\x60gwx <account> /g;
  s/'gws\s+/'gwx <account> /g;
  s/cliHelp: "gws\s+/cliHelp: "gwx <account> /g;
  if ($in_code) { s/\bgws\s+/gwx <account> /g }
  print;
}
PERL
  perl -e "$script"
}

refresh_skills_src() {
  have git || die "git not installed (needed to fetch gws skills source)" 4
  if [[ -d "$GWX_SKILLS_SRC/.git" ]]; then
    git -C "$GWX_SKILLS_SRC" fetch --depth 1 origin main >/dev/null 2>&1 \
      && git -C "$GWX_SKILLS_SRC" reset --hard origin/main >/dev/null 2>&1
  else
    mkdir -p "$(dirname "$GWX_SKILLS_SRC")"
    git clone --depth 1 --filter=blob:none --sparse "$GWS_REPO_URL" "$GWX_SKILLS_SRC" >/dev/null 2>&1 \
      || die "failed to clone $GWS_REPO_URL" 4
    git -C "$GWX_SKILLS_SRC" sparse-checkout set skills >/dev/null 2>&1
  fi
  [[ -d "$GWX_SKILLS_SRC/skills" ]] || die "no skills/ directory in cloned repo" 4
}

cmd_skills_install() {
  local include_recipes=0 include_personas=0 install_all=0
  local -a requested_skills=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skill)
        shift
        while [[ $# -gt 0 && "$1" != --* ]]; do requested_skills+=("$1"); shift; done
        ;;
      --recipes)  include_recipes=1; shift ;;
      --personas) include_personas=1; shift ;;
      --all)      install_all=1; shift ;;
      -h|--help)  print_skills_help; exit 0 ;;
      *) die "unknown flag: $1 (run 'gwx skills --help')" 2 ;;
    esac
  done

  # --all overrides --skill; warn so the user knows their --skill list was ignored
  # rather than installed-and-also-everything-else.
  if [[ "$install_all" -eq 1 && "${#requested_skills[@]}" -gt 0 ]]; then
    err "warning: --all overrides --skill ${requested_skills[*]} (installing everything)"
  fi

  echo "→ refreshing gws source at $GWX_SKILLS_SRC"
  refresh_skills_src

  # Build the list of skills to install
  local -a target_skills=()
  if [[ "$install_all" -eq 1 ]]; then
    while IFS= read -r dir; do target_skills+=("$(basename "$dir")"); done \
      < <(find "$GWX_SKILLS_SRC/skills" -maxdepth 1 -mindepth 1 -type d | sort)
  elif [[ "${#requested_skills[@]}" -gt 0 ]]; then
    # Always include gws-shared — every gws-* skill depends on it.
    target_skills=("${requested_skills[@]}" "gws-shared")
  else
    while IFS= read -r dir; do
      local name; name="$(basename "$dir")"
      [[ "$name" == gws-* ]] && target_skills+=("$name")
    done < <(find "$GWX_SKILLS_SRC/skills" -maxdepth 1 -mindepth 1 -type d | sort)
  fi
  if [[ "$include_recipes" -eq 1 ]]; then
    while IFS= read -r dir; do
      local name; name="$(basename "$dir")"
      [[ "$name" == recipe-* ]] && target_skills+=("$name")
    done < <(find "$GWX_SKILLS_SRC/skills" -maxdepth 1 -mindepth 1 -type d | sort)
  fi
  if [[ "$include_personas" -eq 1 ]]; then
    while IFS= read -r dir; do
      local name; name="$(basename "$dir")"
      [[ "$name" == persona-* ]] && target_skills+=("$name")
    done < <(find "$GWX_SKILLS_SRC/skills" -maxdepth 1 -mindepth 1 -type d | sort)
  fi

  # Dedupe (preserve order)
  local -a uniq=()
  local seen_marker=" "
  for s in "${target_skills[@]}"; do
    if [[ "$seen_marker" != *" $s "* ]]; then
      uniq+=("$s")
      seen_marker+="$s "
    fi
  done
  target_skills=("${uniq[@]}")

  [[ "${#target_skills[@]}" -gt 0 ]] || die "no skills selected to install" 2

  mkdir -p ".claude/skills"

  # Rewrite each. Track skipped (suspicious or missing) so we can exit non-zero
  # if the user asked for a specific skill that wasn't found — currently we'd
  # otherwise print "✓ installed N skills" and exit 0 even when the requested
  # skill landed nowhere (the transitive gws-shared still gets counted).
  #
  # Validation runs sequentially in the parent shell (so skipped/count stay
  # correct), then the perl rewrites fan out in parallel — for --all that's
  # ~95 forks, each independent (writes to its own file). All-at-once is fine
  # at this scale; if it ever grew we'd add a bounded semaphore.
  local count=0 skipped=0
  local -a rewrite_pids=()
  for skill in "${target_skills[@]}"; do
    # Refuse anything outside [a-z0-9_-]+ so a hostile upstream can't smuggle
    # path traversal (".." / "/") into a directory it controls.
    if ! [[ "$skill" =~ ^[a-z0-9_][a-z0-9_-]*$ ]]; then
      err "refusing suspicious skill name: $skill"
      skipped=$((skipped+1))
      continue
    fi
    local src="$GWX_SKILLS_SRC/skills/$skill/SKILL.md"
    if [[ ! -f "$src" ]]; then
      err "skill not found upstream: $skill"
      skipped=$((skipped+1))
      continue
    fi
    mkdir -p ".claude/skills/$skill"
    rewrite_skill < "$src" > ".claude/skills/$skill/SKILL.md" &
    rewrite_pids+=($!)
    count=$((count+1))
  done
  for pid in "${rewrite_pids[@]}"; do wait "$pid" 2>/dev/null || true; done

  # Always also install gwx:cli — the wrapper-contract skill that the gws-*
  # skills assume is loaded. Without it, an agent in this directory has no
  # way to learn the multi-account contract from the project alone. Copy
  # verbatim (no rewrite — this is our skill, not upstream gws content).
  local cli_src=""
  for candidate in \
    "$(dirname "${BASH_SOURCE[0]}")/../skills/cli/SKILL.md" \
    "$HOME/.local/share/gwx/skills/cli/SKILL.md" \
    "/usr/local/share/gwx/skills/cli/SKILL.md"; do
    if [[ -f "$candidate" ]]; then cli_src="$candidate"; break; fi
  done
  if [[ -n "$cli_src" ]]; then
    mkdir -p ".claude/skills/gwx-cli"
    cp "$cli_src" ".claude/skills/gwx-cli/SKILL.md"
    target_skills+=("gwx-cli")
    count=$((count+1))
  else
    err "warning: could not locate gwx:cli source (searched standard install paths)"
    err "          skills will work but agents won't auto-learn the wrapper contract"
  fi

  # Manifest — tracks installed skill names + upstream SHA in
  # .claude/skills/.gwx-manifest.json so uninstall and drift checks have ground truth.
  local sha names_json ts
  sha="$(git -C "$GWX_SKILLS_SRC" rev-parse HEAD 2>/dev/null || echo unknown)"
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if have jq; then
    names_json="$(printf '%s\n' "${target_skills[@]}" | jq -R . | jq -s -c .)"
  else
    # fallback: hand-build a JSON array
    local first=1 acc=""
    for s in "${target_skills[@]}"; do
      if [[ "$first" -eq 1 ]]; then acc="\"$s\""; first=0; else acc="$acc,\"$s\""; fi
    done
    names_json="[$acc]"
  fi
  printf '{"upstream_sha":"%s","installed":%s,"timestamp":"%s"}\n' \
    "$sha" "$names_json" "$ts" > ".claude/skills/.gwx-manifest.json"

  echo
  echo "✓ installed $count skills to $(pwd)/.claude/skills/"
  echo "  upstream SHA: ${sha:0:8}"
  echo "  manifest:     .claude/skills/.gwx-manifest.json"

  # If anything was skipped (typo'd skill name, hostile name) exit non-zero so
  # callers (and the user reading the terminal) don't think a partial install
  # was a full success.
  [[ "$skipped" -eq 0 ]] || exit 4
}

cmd_skills_uninstall() {
  local -a only=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skill)
        shift
        while [[ $# -gt 0 && "$1" != --* ]]; do only+=("$1"); shift; done
        ;;
      -h|--help)  print_skills_help; exit 0 ;;
      *) die "unknown flag: $1" 2 ;;
    esac
  done

  local manifest=".claude/skills/.gwx-manifest.json"
  [[ -f "$manifest" ]] || die "no manifest at $manifest — nothing to uninstall here" 2

  local -a installed=()
  if have jq; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -n "$line" ]] && installed+=("$line")
    done < <(jq -r '.installed[]' "$manifest")
  else
    # crude fallback parser
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -n "$line" ]] && installed+=("$line")
    done < <(grep -oE '"[^"]+"' "$manifest" | sed 's/"//g' | grep -E '^(gws|recipe|persona)-')
  fi

  local count=0
  for skill in "${installed[@]}"; do
    # Defense in depth: validate names from the manifest before using as a
    # path component, so a tampered manifest can't aim rm -rf outside the dir.
    if ! [[ "$skill" =~ ^[a-z0-9_][a-z0-9_-]*$ ]]; then
      err "manifest contains suspicious skill name (skipping): $skill"
      continue
    fi
    if [[ "${#only[@]}" -gt 0 ]]; then
      local match=0
      for k in "${only[@]}"; do [[ "$k" == "$skill" ]] && match=1; done
      [[ "$match" -eq 1 ]] || continue
    fi
    if [[ -d ".claude/skills/$skill" ]]; then
      rm -rf ".claude/skills/$skill"
      count=$((count+1))
    fi
  done

  if [[ "${#only[@]}" -eq 0 ]]; then
    rm -f "$manifest"
    echo "✓ removed $count skills + manifest"
  else
    echo "✓ removed $count skills (manifest preserved)"
  fi
}

cmd_skills() {
  local sub="${1:-}"
  case "$sub" in
    install)   shift; cmd_skills_install "$@" ;;
    uninstall) shift; cmd_skills_uninstall "$@" ;;
    ''|-h|--help|help) print_skills_help ;;
    *) die "unknown skills subcommand '$sub'. usage: gwx skills <install|uninstall>" 2 ;;
  esac
}

main() {
  # No args at all → top-level help.
  if [[ $# -eq 0 ]]; then print_help; return 0; fi

  # An empty quoted first arg (e.g. `gwx "" gmail +triage`) is a usage error,
  # not a request for help — distinguish from the no-args case above.
  if [[ -z "$1" ]]; then
    err "empty argument; usage: gwx <account> <gws args...>  or  gwx --help"
    exit 2
  fi

  local first="$1"
  case "$first" in
    --help|-h|help)         print_help ;;
    --version|-V|version)   echo "gwx 0.1.0" ;;
    init)                   shift; cmd_init "$@" ;;
    login)                  shift; cmd_login "$@" ;;
    logout)                 shift; cmd_logout "$@" ;;
    remove)                 shift; cmd_remove "$@" ;;
    whoami)                 shift; cmd_whoami "$@" ;;
    skills)                 shift; cmd_skills "$@" ;;
    *)                      dispatch "$@" ;;
  esac
}

main "$@"
